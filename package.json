{
  "name": "poc-side-by-side",
  "version": "1.0.0",
  "description": "Order Enrichment Dashboard — POC Side-by-Side SAP BTP / S/4HANA",
  "dependencies": {
    "@sap/cds": "^9",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2"
  },
  "scripts": {
    "start": "cds-serve",
    "dev": "cds watch"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "impl": "@cap-js/sqlite",
        "credentials": {
          "url": ":memory:"
        }
      }
    }
  },
  "private": true
}
